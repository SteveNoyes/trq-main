{
  "manifest_version": 3,
  "name": "Prompt Coach",
  "version": "1.0.0",
  "description": "A structured prompt-building assistant that helps users create clearer, more effective AI prompts.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "Prompt Coach",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "permissions": [
    "clipboardWrite"
  ],
  "host_permissions": []
}